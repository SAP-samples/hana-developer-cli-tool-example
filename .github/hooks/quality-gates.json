{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/pre-tool-use.js",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/post-tool-use.js",
        "timeout": 60
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/stop.js",
        "timeout": 10
      }
    ]
  }
}
